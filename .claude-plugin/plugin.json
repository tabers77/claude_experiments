{
  "name": "claude-library",
  "version": "1.0.0",
  "description": "23 reusable skills, 2 agents, and smart hooks for architecture mapping, code review, safe refactoring, learning, and quality gates — works in any project.",
  "author": {
    "name": "delacruzribadenc",
    "url": "https://github.com/tabers77"
  },
  "homepage": "https://github.com/tabers77/claude_experiments",
  "repository": "https://github.com/tabers77/claude_experiments",
  "license": "MIT",
  "keywords": [
    "skills",
    "agents",
    "hooks",
    "code-review",
    "architecture",
    "refactoring",
    "learning",
    "quality",
    "security",
    "planning"
  ],
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/scripts/session-start-hook.py\"",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/scripts/skill-activation-hook.py\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$CLAUDE_FILE_PATH\" | grep -qE '^(protected/|migrations/|.env)'; then echo \"BLOCKED: Cannot modify protected path: $CLAUDE_FILE_PATH\" && exit 2; fi"
          },
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/scripts/sensitive-file-hook.py\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$CLAUDE_COMMAND\" | grep -qE 'git (push --force|reset --hard|clean -f)'; then echo \"BLOCKED: Destructive git command requires manual execution\" && exit 2; fi"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$CLAUDE_FILE_PATH\" | grep -q '\\.py$'; then ruff check \"$CLAUDE_FILE_PATH\" || echo 'Lint issues found'; fi"
          }
        ]
      }
    ]
  }
}
