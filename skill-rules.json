{
  "rules": [
    {
      "skill": "architecture-arch",
      "triggers": ["map the codebase", "architecture", "how is .* structured", "execution path", "codebase structure", "mental model"],
      "description": "Map codebase structure before touching anything"
    },
    {
      "skill": "meta-project-setup",
